extends baseEmail

block content 
  p Hello #{firstName}
  p You requested to reset your password. Please click the link below to set a new password
  p Reset Password Link: #{url}
  table.btn.btn-primary(role='presentation' border='0' cellpadding='0' cellspacing='0')
    tbody
      tr
        td(align='left')
          table(role='presentation' border='0' cellpadding='0' cellspacing='0')
            tbody
              tr
                td
                  a(href=`${url}` target='_blank') Reset your password
  p This link is valid for 10 minutes. If you did not request a password reset, please ignore this email.
  p Thank you, Your App Team